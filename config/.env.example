# Reverse Arbitrage Bot - Environment Configuration Template
# Copy to .env and fill in values

# =============================================================================
# TRADING MODE (CRITICAL - PRODUCTION GUARD)
# =============================================================================
PAPER_TRADING=true
ENVIRONMENT=production
LIVE_TRADING_CONFIRMED=false

# =============================================================================
# POLYMARKET CREDENTIALS (REQUIRED FOR LIVE)
# =============================================================================
# Get from https://polymarket.com/api
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# =============================================================================
# REVERSE ARBITRAGE STRATEGY PARAMETERS
# Target: BTC/ETH 15m Up/Down markets
# Buy underdog at 7-10¢, hedge favorite at 90-95¢
# =============================================================================
REVERSE_ARB_ENABLED=true
REVERSE_ARB_BTC_ONLY=true
REVERSE_ARB_ETH_ONLY=false
REVERSE_ARB_HFT_MODE=true
REVERSE_ARB_DRY_RUN=true

# Market selection
REVERSE_ARB_MIN_CLOSE_MIN=2
REVERSE_ARB_MIN_CLOSE_MAX=5
REVERSE_ARB_SCAN_INTERVAL=5

# Price windows (BOTH legs must be within range)
REVERSE_ARB_CHEAP_BUY_MIN=0.07      # Underdog ask <= $0.10
REVERSE_ARB_CHEAP_BUY_MAX=0.10
REVERSE_ARB_EXPENSIVE_BUY_MIN=0.90  # Favorite ask >= $0.90
REVERSE_ARB_EXPENSIVE_BUY_MAX=0.95

# Order sizing (USDC)
REVERSE_ARB_CHEAP_ORDER_USD=50
REVERSE_ARB_EXPENSIVE_ORDER_USD=100

# Execution
REVERSE_ARB_ORDER_TYPE=FOK

# Edge & risk
REVERSE_ARB_MIN_EDGE_BPS=100
REVERSE_ARB_MAX_SLIPPAGE_BPS=50
REVERSE_ARB_MAX_POSITION_USD=2000
REVERSE_ARB_FEE_BPS=75

# =============================================================================
# RISK LIMITS
# =============================================================================
RISK_MAX_DAILY_LOSS_USD=500
RISK_MAX_GROSS_EXPOSURE_USD=10000
RISK_MAX_CONCURRENT_POSITIONS=5
RISK_MAX_POSITION_PER_MARKET_USD=2000
RISK_CIRCUIT_BREAKER_DAILY_DRAWDOWN_PCT=0.05

# =============================================================================
# MARKET DATA ENDPOINTS
# =============================================================================
GAMMA_API_URL=https://gamma-api.polymarket.com
CLOB_API_URL=https://clob.polymarket.com
CLOB_WS_URL=wss://clob.polymarket.com/ws
POLYGON_RPC_URL=https://polygon-rpc.com

# =============================================================================
# API SERVER
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8080
API_ENABLED=true
METRICS_PORT=9090

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=sqlite:///./data/arbitrage.db
REDIS_URL=redis://localhost:6379/0
